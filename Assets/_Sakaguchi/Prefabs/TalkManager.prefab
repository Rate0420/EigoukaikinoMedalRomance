      TalkLength: 3
    Talk2:
      TextBody: 
      TextName: 
      TalkFace: {fileID: 0}
      TalkLength: 0
  - Talk1:
      TextBody: "...\u4F55\u304B\u304A\u304B\u3057\u306A\u3053\u3068\u306F\u7121\u3044\u3088\u306A\uFF1F"
      TextName: "\u52A0\u6D41"
