      TalkLength: 3
    Talk2:
      TextBody: 
      TextName: 
      TalkFace: {fileID: 0}
      TalkLength: 0
  - Talk1:
      TextBody: "...\u6551\u6E08\u3092\u3001\u5168\u3066\u306E\u3082\u306E\u306B\u3002"
      TextName: "\u30EA\u30EA\u30B9"
