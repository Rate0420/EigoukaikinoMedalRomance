      TalkLength: 3
    Talk2:
      TextBody: 
      TextName: 
      TalkFace: {fileID: 0}
      TalkLength: 0
  - Talk1:
      TextBody: "\u3046\uFF5E\u3093...\u975E\u65E5\u5E38\u306E\u4E88\u611F"
      TextName: "\u6FAA\u97F3"
      TalkFace: {fileID: 21300000, guid: b9c4d519b01bd6246b4251c5e1dd23aa, type: 3}
      TalkLength: 2
    Talk2:
      TextBody: 
      TextName: 
      TalkFace: {fileID: 0}
      TalkLength: 0
  - Talk1:
      TextBody: "\u3088\u3002\u76F8\u5909\u3089\u305A\u304A\u524D\u306F\u30D2\u30DE\u305D\u3046\u3060\u306A"
      TextName: "\u52A0\u6D41"
