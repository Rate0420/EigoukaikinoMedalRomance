  - text: "\u805E\u304D\u6163\u308C\u305F\u3001\u3057\u304B\u3057\u4ECA\u306F\u5FC3\u81D3\u306B\u60AA\u3059\u304E\u308B\u307B\u3069\u5143\u6C17\u306A\u58F0\u304C\u3057\u305F\u3002\r\n\u632F\u308A\u5411\u304F\u3068\u3001\u305D\u3053\u306B\u7ACB\u3063\u3066\u3044\u305F\u306E\u306F\u3001\u5F8C\u8F29\u306E\u5929\u5BAE\u51A5\u4F9D\u3060\u3063\u305F\u3002"
