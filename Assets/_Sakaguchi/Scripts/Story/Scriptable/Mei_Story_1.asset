  - text: "\u4ECA\u65E5\u306E\u98DF\u8CBB\u3059\u3089\u602A\u3057\u3044\u3002\u8CA1\u5E03\u306E\u4E2D\u8EAB\u306F\u6570\u679A\u306E\u5C0F\u92AD\u3060\u3051\u3002\r\n\u30B9\u30FC\u30D1\u30FC\u306E\u7279\u58F2\u54C1\u3059\u3089\u8CB7\u3048\u306A\u3044\u72B6\u6CC1\u306B\u3001\u4FFA\u306F\u982D\u3092\u62B1\u3048\u305F\u3002"
