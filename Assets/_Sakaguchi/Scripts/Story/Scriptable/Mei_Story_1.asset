  - text: "\u6700\u521D\u306F\u6B53\u559C\u3057\u305F\u3002\u3053\u308C\u3067\u3082\u3046\u501F\u91D1\u5730\u7344\u3068\u306F\u304A\u3055\u3089\u3070\u3060\u3068\u3002\r\n\u3060\u304C\u3001\u73FE\u5B9F\u306F\u9055\u3063\u305F\u3002\r"
