  charactorType: 2
  characterName: Arisugawa Hinata
  characterName_JP: "\u6709\u6816\u5DDD \u967D\u5411"
  sprites:
  - {fileID: 21300000, guid: 2334cf3e3956b9a43ae97f722f55d68b, type: 3}
  - {fileID: 21300000, guid: 22a1df77a8b7c7d4589186d6b226ec8e, type: 3}
  - {fileID: 21300000, guid: a67b9976ab2f7bf48a54b027371d1437, type: 3}
  - {fileID: 21300000, guid: 0a4e6f8ccbff48a42a2eb9c109d6d5bf, type: 3}
  voice: []
  menuTexts:
  - "\u3084\u3063\u307B\u30FC\u3001\u304A\u306B\u30FC\u3055\u30FC\u3093\u3002\\n\u4ECA\u65E5\u3082\u8CA0\u306E\u30AA\u30FC\u30E9\u30DE\u30B7\u30DE\u30B7\u3060\u306D\u3047\uFF1F\\n\u305D\u306E\u3046\u3061\u307D\u3063\u304F\u308A\u6B7B\u306B\u305D\u30FC\uFF01"
  - "\u304A\u306B\u30FC\u3055\u3093\u3063\u3066\u30B6\u30B3\u30B6\u30B3\u3067\u3088\u308F\u3088\u308F\u306E\u304F\u305B\u306B\\n\u307B\u3093\u3063\u3068\u4EBA\u3092\u52A9\u3051\u3088\u3046\u3068\u3059\u308B\u3088\u306D\uFF1F\\n...\u307E\u3041\u3001\u305D\u3046\u3044\u3046\u3068\u3053\u308D\u3082\u597D\u304D\u306A\u3093\u3060\u3051\u3069...\u306A\u30FC\u3093\u3066\u306D\uFF01"
  - "\u304A\u306B\u30FC\u3055\u3093\u3055\u3041\u3001\u79C1\u306B\u69CB\u3044\u307E\u304F\u3063\u3066\u308B\u3051\u3069\u306A\u3093\u3067\u3047\uFF1F\\n\u3078\u3093\u305F\u3044\u3055\u3093\uFF1F...\u307E\u3041\u3001\u60AA\u3044\u6C17\u306F\u3057\u306A\u3044\u3051\u3069\u306D\u30FC\uFF01"
  - "\u304A\u306B\u30FC\u3055\u3093\u30B2\u30FC\u30E0\u3070\u3063\u304B\u308A\u30FC\u3001\u305A\u3063\u3068\u305D\u308C\u3060\u3051\u3067\u5358\u4F4D\u5927\u4E08\u592B\u3045\uFF1F\\n\u5EC3\u4EBA\u306E\u672A\u6765\u3057\u304B\u898B\u3048\u306A\u3044\u3088\u3049\uFF1F"
  charaExp:
  - "\u611B\u6597\u306B\u4ED8\u304D\u307E\u3068\u3046\u8B0E\u306E\u5B50\u4F9B\u3002\\n\u521D\u5BFE\u9762\u304B\u3089\u8DDD\u96E2\u611F\u304C\u304A\u304B\u3057\u304F\u3001\u5B8C\u5168\u306B\u5E74\u4E0A\u3092\u8210\u3081\u305F\u614B\u5EA6\u3002\u200B\\n\u8EFD\u53E3\u30FB\u717D\u308A\u30FB\u76AE\u8089\u304C\u57FA\u672C\u30B9\u30BF\u30A4\u30EB\u3067\u3001\u3068\u306B\u304B\u304F\u751F\u610F\u6C17\u3002\u200B\\n\u3057\u304B\u3057\u305D\u306E\u4E00\u65B9\u3067\u3001\u5927\u4EBA\u3067\u3082\u77E5\u3089\u306A\u3044\u3088\u3046\u306A\u77E5\u8B58\u3092\u6301\u3063\u3066\u3044\u3066\u200B\\n\u72B6\u6CC1\u3092\u5999\u306B\u6B63\u78BA\u306B\u628A\u63E1\u3057\u3066\u3001\u30BF\u30A4\u30DF\u30F3\u30B0\u3088\u304F\u73FE\u308C\u308B\u200B\\n\u306A\u3069\u3001\u660E\u3089\u304B\u306B\u666E\u901A\u306E\u5B50\u4F9B\u3067\u306F\u306A\u3044\u3002\\n\u672C\u4EBA\u66F0\u304F\u300C\u9762\u767D\u3044\u304B\u3089\u4E00\u7DD2\u306B\u3044\u308B\u300D\u3068\u306E\u3053\u3068\u3060\u304C\u3001\u200B\\n\u6642\u6298\u89B3\u5BDF\u3057\u3066\u3044\u308B\u3088\u3046\u306A\u8996\u7DDA\u3060\u3063\u305F\u308A\u7269\u6182\u3052\u306A\u76EE\u7DDA\u3092\u5411\u3051\u3066\u304F\u308B\u3002"
  - "\u305D\u306E\u6B63\u4F53\u306F\u9B54\u6CD5\u5C11\u5973\u3002\\n\u305F\u3060\u3057\u4E00\u822C\u7684\u306A\u3082\u306E\u3067\u306F\u306A\u304F\u3001\u200B\\n\u5951\u7D04\u30FB\u6226\u95D8\u30FB\u5F79\u76EE\u306B\u7E1B\u3089\u308C\u305F\u5B58\u5728\u3067\u3042\u308A\u3001\u672C\u4EBA\u306B\u3068\u3063\u3066\u306F\u546A\u3044\u3067\u3057\u304B\u306A\u3044\u3002\\n\u5E74\u9F62\u306F\u4E0D\u8A73\u3002\u5916\u898B\u306F\u5B50\u4F9B\u306E\u307E\u307E\u56FA\u5B9A\u3055\u308C\u3066\u3044\u308B\u304C\u3001\u9577\u3044\u6642\u9593\u3092\u7E70\u308A\u8FD4\u3057\u3066\u304D\u3066\u3044\u308B\u3002\\n\u5F7C\u5973\u306F\u602A\u73FE\u8C61\u3001\u7570\u5E38\u306A\u5B58\u5728\u3001\u6B6A\u3093\u3060\u904B\u547D\u3092\u6301\u3064\u4EBA\u9593\u3092\u611F\u77E5\u30FB\u89B3\u6E2C\u30FB\u5BFE\u51E6\u3059\u308B\u5F79\u5272\u3092\u6301\u3063\u3066\u3044\u308B\u3002\\n\u4E3B\u4EBA\u516C\u3092\u89B3\u6E2C\u3057\u305F\u969B\u3001\u81EA\u5206\u3068\u540C\u3058\u3088\u3046\u306B\u30EB\u30FC\u30D7\u306B\u7E1B\u3089\u308C\u305F\u4EBA\u9593\u3067\u3042\u308B\u3053\u3068\u3002\u200B\\n\u305D\u3057\u3066\u672A\u77E5\u306E\u529B\u3092\u6301\u3063\u3066\u3044\u308B\u305F\u3081\u3001\\n\u201C\u81EA\u5206\u306E\u546A\u3044\u3092\u7D42\u308F\u3089\u305B\u308B\u9375\u201D\\n\u304B\u3082\u3057\u308C\u306A\u3044\u3068\u8003\u3048\u3001\u305D\u306E\u53EF\u80FD\u6027\u306B\u8CED\u3051\u3066\u3044\u308B\u3002\u200B\\n\u305D\u306E\u305F\u3081\u614B\u5EA6\u306F\u4E00\u8CAB\u3057\u3066\u8EFD\u3044\u304C\u3001\u5185\u5FC3\u3067\u306F\u304B\u306A\u308A\u5FC5\u6B7B\u3002"
  likeability: 0
