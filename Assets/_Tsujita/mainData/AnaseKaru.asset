  charactorType: 1
  characterName: Anase Karu
  characterName_JP: "\u4E7E\u98A8 \u52A0\u6D41"
  sprites:
  - {fileID: 21300000, guid: d26fcec398d7516448c3fb66a6f0d21d, type: 3}
  - {fileID: 21300000, guid: f61c9841035e2d648b2ac3fee65f2e94, type: 3}
  - {fileID: 21300000, guid: ef9fa3ff31efe564caeb456382e0f6c5, type: 3}
  - {fileID: 21300000, guid: d6064e54d2a78ff4089de9be87acd9e9, type: 3}
  voice: []
  menuTexts:
  - "\u304A\u3044\u3053\u3089\u3001\u30E1\u30C0\u30EB\u30B2\u30FC\u30E0\u3070\u3063\u304B\u3057\u3066\u306D\u30FC\u3067\u307E\u3063\u3068\u3046\u306B\u50CD\u3051\u3002\\n\u3093\u306A\u3053\u3068\u3067\u5F97\u305F\u91D1\u306A\u3093\u3066\u7D76\u5BFE\u308D\u304F\u306A\u3082\u3093\u3058\u3083\u306D\u3047\u305E\uFF1F"
  - "\u304A\u524D\u3001\u81EA\u899A\u306A\u3044\u3060\u308D\u3046\u3051\u3069\u8D85\u30C8\u30E9\u30D6\u30EB\u4F53\u8CEA\u3060\u304B\u3089\u306A\uFF1F\\n\u305D\u3053\u3093\u3068\u3053\u81EA\u899A\u3057\u3066\u306A\u3093\u304B\u3042\u3063\u305F\u3089\u3061\u3083\u3093\u3068\u8A00\u3048\u3088\u3002"
  - "...\u306A\u3093\u3064\u30FC\u304B\u3055\u3001\u3053\u3053\u307E\u3067\u4FFA\u306B\u3064\u3044\u3066\u304F\u308B\u5974\u306F\u521D\u3081\u3066\u3060\u3002\\n...\u305D\u3001\u305D\u3093\u3060\u3051\u3060\u3088\uFF01\uFF01"
  - "\u3088\u3002\u76F8\u5909\u3089\u305A\u3057\u3051\u305F\u9762\u3057\u3066\u3093\u306A\u3041\u3002\\n\u307E\u305F\u501F\u91D1\u3067\u3082\u3057\u3066\u3093\u306E\u304B\u3041\uFF1F"
  charaExp:
  - "\u4E0D\u826F\u3063\u307D\u3044\u898B\u305F\u76EE\u3068\u614B\u5EA6\u306E\u5148\u8F29\u3002\u200B\\n\u53E3\u304C\u60AA\u304F\u3076\u3063\u304D\u3089\u307C\u3046\u3067\u8FD1\u5BC4\u308A\u304C\u305F\u3044\u304C\u3001\u200B\\n\u56F0\u3063\u3066\u3044\u308B\u4EBA\u3092\u898B\u308B\u3068\u7D50\u5C40\u653E\u3063\u3066\u304A\u3051\u306A\u3044\u30BF\u30A4\u30D7\u3002\u200B\\n\u3088\u304F\u55A7\u5629\u3057\u3066\u3044\u308B\u306E\u304B\u3001\u5E38\u306B\u3069\u3053\u304B\u306B\u50B7\u304C\u3042\u308B\u3002\\n\u305F\u3060\u3057\u305D\u306E\u50B7\u306F\u201C\u305F\u3060\u306E\u55A7\u5629\u3067\u306F\u8AAC\u660E\u304C\u3064\u304B\u306A\u3044\u3082\u306E\u201D\u3082\u6DF7\u3056\u3063\u3066\u3044\u308B\u3002\\n\u4E3B\u4EBA\u516C\u306B\u5BFE\u3057\u3066\u3082\u6700\u521D\u306F\u96D1\u306B\u63A5\u3059\u308B\u304C\u3001\u200B\\n\u5371\u306A\u3044\u5834\u6240\u306B\u884C\u304F\u3068\u6B62\u3081\u3001\u4F55\u304B\u3042\u308C\u3070\u7D50\u5C40\u52A9\u3051\u308B\u3002\u200B\\n\u6587\u53E5\u3092\u8A00\u3044\u306A\u304C\u3089\u4E16\u8A71\u3092\u713C\u304F\u3068\u3044\u3046\u5178\u578B\u7684\u306A\u9762\u5012\u898B\u306E\u3044\u3044\u4E0D\u826F\u30BF\u30A4\u30D7\u3002\\n\u307E\u305F\u5999\u306B\u591C\u306E\u8857\u306B\u8A73\u3057\u304F\u3001\u3053\u306E\u8857\u306F\u5371\u967A\u3067\u3042\u308B\u3068\u3088\u304F\u8A00\u3046\u3002"
  - "\u8B0E\u306E\u9AD8\u6027\u80FD\u30AE\u30A2\u3092\u88C5\u7740\u3057\u3001\u4EBA\u9593\u3092\u8D85\u3048\u305F\u529B\u3067\u201C\u7570\u5F62\u306E\u5B58\u5728\u201D\u3068\u6226\u3046\u5C11\u5973\u3002\u200B\\n\u904E\u53BB\u306B\u4E00\u5EA6\u6B7B\u3093\u3067\u3044\u308B\u3002\\n\u305D\u306E\u5F8C\u3001\u3068\u3042\u308B\u65BD\u8A2D\u306B\u3088\u3063\u3066\u56DE\u53CE\u30FB\u518D\u69CB\u6210\u3055\u308C\u3001\u30AE\u30A2\u3078\u306E\u9069\u5408\u8005\u3068\u3057\u3066\u8607\u3063\u305F\u3002\\n\u73FE\u5728\u306F\u8EAB\u4F53\u80FD\u529B\u306E\u5F37\u5316\u3001\u9AD8\u901F\u518D\u751F\u3001\u75DB\u899A\u306E\u920D\u5316\u306A\u3069\u306E\u529B\u3092\u6301\u3064\u304C\u3001\\n\u305D\u308C\u306F\u540C\u6642\u306B\u4EBA\u9593\u304B\u3089\u9038\u8131\u3057\u3066\u3044\u308B\u8A3C\u62E0\u3067\u3082\u3042\u308A\u3001\u672C\u4EBA\u306F\u305D\u308C\u3092\u7406\u89E3\u3057\u3066\u304A\u308A\u3001\u200B\\n\u81EA\u5206\u306F\u666E\u901A\u306B\u306F\u623B\u308C\u306A\u3044\u3002\u3060\u304B\u3089\u3053\u305D\u201C\u4EBA\u3068\u3057\u3066\u6B63\u3057\u304F\u3042\u308A\u305F\u3044\u201D\u200B\\n\u3068\u3044\u3046\u5F37\u3044\u4FE1\u5FF5\u3092\u6301\u3064\u3088\u3046\u306B\u306A\u3063\u305F\u3002\u200B\\n\u5F7C\u5973\u306E\u8EAB\u4F53\u306F\u201C\u6575\u5074\u201D\u306B\u8FD1\u3044\u69CB\u9020\u3002\u200B\\n\u30AE\u30A2\u306F\u5236\u5FA1\u88C5\u7F6E\u3067\u3042\u308A\u3001\u540C\u6642\u306B\u899A\u9192\u30C8\u30EA\u30AC\u30FC\u3067\u3042\u308B\u3002\\n\u65BD\u8A2D\u306F\u5F7C\u5973\u3092\u5175\u5668\u3068\u3057\u3066\u5B8C\u6210\u3055\u305B\u3088\u3046\u3068\u3057\u3066\u3044\u308B"
  likeability: 0
