  characterName: Mikumo Sayo
  characterName_JP: "\u4E09\u96F2 \u5C0F\u591C"
  sprites:
  - {fileID: 21300000, guid: 170fd94614513fa4fb46f5459b600054, type: 3}
  - {fileID: 21300000, guid: f4290a6a404247e47af175f7d4537bfc, type: 3}
  - {fileID: 21300000, guid: c2c8e9d5e1503cf4ba4765a976691567, type: 3}
  - {fileID: 21300000, guid: 7c8167568f1cdc041ac320bcd7f6f319, type: 3}
  voice: []
  menuTexts:
  - "\u3046\u3047\u3078\u3078...\u5148\u8F29\u3001\u5148\u8F29\u3068\u3053\u3046\u3057\u3066\u4E8C\u4EBA\u3060\u3051\u306E\u6642\u9593\u3092\u904E\u3054\u3059\u306E...\\n\u79C1\u3001\u597D\u304D\u3067\u3059\u3088..."
  - "...\u5148\u8F29\u3001\u591C\u9053\u306B\u306F\u6C17\u3092\u4ED8\u3051\u3066\u304F\u3060\u3055\u3044\u306D\uFF1F\\n...\u3042\u3063\u3001\u305D\u306E\uFF01\u8105\u3057\u3068\u304B\u3067\u306F\u306A\u304F\u307B\u3093\u3068\u306B...\u3046\u3045..."
  - "..\u3048\u3078\u3078\u3001\u5148\u8F29\u3063\u3066\u304A\u91D1\u6301\u3061\u306A\u3093\u3067\u3059\u306D...\\n\u3061\u3087\u3063\u3068\u5206\u3051\u3066\u304F\u3060\u3055\u3044\u3088..."
  - "...\u305B\u3001\u5148\u8F29\u3001\u3069\u3046\u304B\u3057\u307E\u3057\u305F...\u304B...?\\n...\u3048\u3001\u3048\u3078\u3078\u3001\u79C1\u306E\u4E8B\u3059\u304D\u306B\u306A\u3063\u3061\u3083\u3044\u307E\u3057\u305F\uFF1F"
  charaExp:
  - "\u6B74\u53F2\u7814\u7A76\u30B5\u30FC\u30AF\u30EB\u306E\u5F8C\u8F29\u3002\u200B\\n\u6975\u5EA6\u306E\u4EBA\u898B\u77E5\u308A\u3067\u3001\u5E38\u306B\u304A\u3069\u304A\u3069\u3057\u3066\u3044\u308B\u3002\u200B\\n\u58F0\u3082\u5C0F\u3055\u304F\u3001\u4F1A\u8A71\u3082\u9014\u5207\u308C\u304C\u3061\u3067\u3001\u3044\u304B\u306B\u3082\u983C\u308A\u306A\u3044\u5370\u8C61\u3002\u200B\\n\u30B5\u30FC\u30AF\u30EB\u306F\u307B\u307C\u6A5F\u80FD\u3057\u3066\u304A\u3089\u305A\u3001\u5B9F\u8CEA\u4E3B\u4EBA\u516C\u3068\u5C0F\u591C\u306E\u4E8C\u4EBA\u304D\u308A\u306E\u7A7A\u9593\u306B\u306A\u3063\u3066\u3044\u308B\u3002\\n\u3068\u306B\u304B\u304F\u6C17\u914D\u304C\u8584\u304F\u3001\u6C17\u914D\u304C\u3084\u305F\u3089\u8584\u304F\u6C17\u3065\u3044\u305F\u3089\u3044\u305F\u308A\u3001\u8DB3\u97F3\u304C\u3057\u306A\u304B\u3063\u305F\u308A\u3001\\n\u8996\u7DDA\u3092\u611F\u3058\u308B\u3053\u3068\u304C\u3042\u308B\u306A\u3069\u3001\u5999\u306A\u9055\u548C\u611F\u304C\u3042\u308B\u3002\u200B"
  - "\u7532\u8CC0\u5FCD\u8005\u306E\u672B\u88D4\u3002\u73FE\u4EE3\u306B\u751F\u304D\u308B\u201C\u5FCD\u201D\u3002\\n\u5E7C\u3044\u9803\u304B\u3089\u5FB9\u5E95\u3057\u305F\u6559\u80B2\u3092\u53D7\u3051\u3001\u96A0\u5BC6\u8ADC\u5831\u6697\u6BBA\u3092\u5F53\u305F\u308A\u524D\u306E\u3082\u306E\u3068\u3057\u3066\u80B2\u3063\u3066\u304D\u305F\u3002\\n\u5185\u6C17\u3067\u304A\u3069\u304A\u3069\u3057\u305F\u6027\u683C\u306F\u201C\u7D20\u201D\u3067\u3042\u308B\u304C\u3001\u304A\u3069\u304A\u3069\u3057\u306A\u304C\u3089\u3082\u78BA\u5B9F\u306B\u6575\u3092\u3057\u3068\u3081\u308B\u3002\\n\u5272\u3068\u6C17\u5F31\u306A\u6027\u683C\u306B\u898B\u3048\u308B\u304C\u7D50\u69CB\u4E0A\u304B\u3089\u76EE\u7DDA\u3067\u5C0A\u5927\u3067\u539A\u304B\u307E\u3057\u3044\u6027\u683C\u3060\u3063\u305F\u308A\u3059\u308B\u3002
    \u200B"
