  characterName: RoufonEnergeiaVermilion
  characterName_JP: "\u30EB\u30D5\u30A9\u30F3\u30FB\u30A8\u30CD\u30EA\u30A2\u30FB\u30F4\u30A7\u30EB\u30DF\u30EA\u30AA\u30F3"
  sprites:
  - {fileID: 21300000, guid: e32daa00f138370489dc8935db9596dd, type: 3}
  - {fileID: 21300000, guid: d88f600bcf13fa743a5c7daac1b5497a, type: 3}
  - {fileID: 21300000, guid: c648fb1017e442c4ebff511319106528, type: 3}
  - {fileID: 21300000, guid: 4498fc681d73edf4dab37274426b1887, type: 3}
  voice: []
  menuTexts:
  - "...\u3042\u3089\u3001\u307C\u30FC\u3063\u3068\u3057\u3066\u3069\u3046\u3057\u305F\u306E\uFF1F\\n...\u3075\u3075\u3001\u79C1\u306B\u898B\u3068\u308C\u3066\u3057\u307E\u3063\u305F\u304B\u3057\u3089\uFF1F"
  - "\u4E00\u3064\u5FE0\u544A\u3088\u3002\u305D\u306E\u91D1\u3092\u751F\u307F\u51FA\u3059\u529B\u3092\u904E\u4FE1\u3057\u3059\u304E\u306A\u3044\u3053\u3068\u306D\u3002\\n...\u307E\u3041\u3001\u3082\u3046\u305D\u308C\u306A\u3057\u3067\u306F\u751F\u304D\u3089\u308C\u306A\u3044\u3067\u3057\u3087\u3046\u3051\u3069\u3002"
  - "...\u5C11\u3057\u8840\u304C\u6B32\u3057\u304F\u306A\u3063\u3066\u304D\u305F\u308F\u306D\u3002...\u306D\u3047\u3001\u30A2\u30A4\u30C8\u3002\\n\u5C11\u3057\u6A2A\u306B\u306A\u308A\u306A\u3055\u3044\u3001...\u5927\u4E08\u592B\u3001\u3061\u3087\u3063\u3068\u30AF\u30E9\u30C3\u3068\u3057\u3066...\\n\u6C17\u6301\u3061\u3088\u304F\u3066\u307C\u30FC\u3063\u3068\u3057\u3066\u3057\u307E\u3046\u3060\u3051\u3088...\u3075\u3075\u3075..."
  - "...\u975E\u529B\u306A\u4EBA\u306E\u8EAB\u3067\u3001\u79C1\u3068\u3053\u3053\u307E\u3067\u306E\u6642\u9593\u3092\u904E\u3054\u3057\u305F\u8005\u306F\u3044\u306A\u304B\u3063\u305F\u308F\u3002\\n...\u8CB4\u65B9\u3001\u51C4\u304F\u9762\u767D\u3044\u308F\u3002"
  charaExp:
  - "\u6C17\u54C1\u3042\u308B\u7ACB\u3061\u632F\u308B\u821E\u3044\u3068\u3001\u3069\u3053\u304B\u829D\u5C45\u304C\u304B\u3063\u305F\u8A00\u52D5\u3092\u3059\u308B\u8B0E\u306E\u5973\u6027\u3002\u200B\\n\u82E5\u304F\u898B\u3048\u308B\u304C\u660E\u3089\u304B\u306B\u5927\u4EBA\u3073\u3066\u304A\u308A\u3001\u5E38\u4EBA\u306E\u30BD\u30EC\u3067\u306F\u306A\u3044\u5727\u5012\u7684\u306A\u5B58\u5728\u611F\u3092\u653E\u3064\u3002\\n\u57FA\u672C\u7684\u306B\u4EBA\u3092\u898B\u4E0B\u3057\u3066\u3044\u308B\u304C\u3001\u305D\u308C\u306F\u60AA\u610F\u3067\u306F\u306A\u304F\u201C\u683C\u306E\u9055\u3044\u201D\u306B\u3088\u308B\u3082\u306E\u3002\\n\u5F37\u8005\u306B\u306F\u656C\u610F\u3092\u3001\u5F31\u8005\u306B\u306F\u8208\u5473\u3092\u793A\u3055\u306A\u3044\u3002\u200B\\n\u3057\u304B\u3057\u4E3B\u4EBA\u516C\u306B\u5BFE\u3057\u3066\u3060\u3051\u306F\u5999\u306A\u95A2\u5FC3\u3092\u6301\u3061\u3001\u3069\u3053\u304B\u5947\u7570\u306A\u7269\u3092\u898B\u308B\u76EE\u3092\u5411\u3051\u3066\u304F\u308B\u3002"
  - "150\u5E74\u4EE5\u4E0A\u3092\u751F\u304D\u308B\u5438\u8840\u9B3C\u3002\\n\u540D\u9580\u3067\u3042\u308B\u30F4\u30A7\u30EB\u30DF\u30EA\u30AA\u30F3\u4E00\u65CF\u306E\u51FA\u3067\u3042\u308A\u306A\u304C\u3089\u3001\u200B\\n\u9B54\u8853\u3084\u7737\u5C5E\u306B\u983C\u3089\u305A\u3001\u7D14\u7C8B\u306A\u8089\u4F53\u3068\u6280\u8853\u306E\u307F\u3067\u6226\u3046\u7570\u7AEF\u3002\u200B\\n\u5F7C\u5973\u306B\u3068\u3063\u3066\u201C\u8840\u201D\u3068\u306F\u5358\u306A\u308B\u6804\u990A\u3067\u306F\u306A\u304F\u5B58\u5728\u305D\u306E\u3082\u306E\u3068\u8003\u3048\u3066\u304A\u308A\u3001\u200B\\n\u5F37\u8005\u306E\u8840\u306F\u4FA1\u5024\u304C\u9AD8\u304F\u3001\u5F31\u8005\u306E\u8840\u306F\u7121\u4FA1\u5024\u3067\u3042\u308B\u3068\u3044\u3046\u6975\u7AEF\u306A\u4FA1\u5024\u89B3\u3092\u6301\u3064\u3002\\n\u6226\u3044\u3068\u306F\u5BFE\u8A71\u3002\u8840\u3092\u555C\u308B\u306E\u306F\u7406\u89E3\u30FB\u80AF\u5B9A\u3002\u52DD\u5229\u306F\u76F8\u624B\u306E\u5B58\u5728\u3092\u53D6\u308A\u8FBC\u3080\u884C\u70BA\u3068\u8003\u3048\u3066\u304A\u308A\u3001\u200B\\n\u5F37\u8005\u3092\u55B0\u3089\u3046\u3053\u3068\u3067\u3001\u81EA\u5206\u3092\u5B8C\u6210\u3055\u305B\u308B\u3068\u3044\u3046\u7F8E\u5B66\u3092\u6301\u3063\u3066\u3044\u308B\u3002\\n\u4EE5\u524D\u30C8\u30FC\u30CA\u30E1\u30F3\u30C8\u3067\u512A\u52DD\u3057\u305F\u3082\u306E\u306E\u3001\u4E3B\u50AC\u8005\u3067\u3042\u308B\u5973\u795E\u306B\u6C7A\u95D8\u3092\u6311\u307F\u6557\u5317\u3092\u55AB\u3059\u308B\u3002\\n\u5999\u306A\u30AA\u30FC\u30E9\u3092\u653E\u3064\u4E3B\u4EBA\u516C\u306E\u8840\u3092\u5438\u3046\u304C\u3001\u5473\u304C\u7121\u304F\u3001\u7406\u89E3\u306E\u53CA\u3070\u306A\u3044\u5B58\u5728\u3002\\n\u307E\u305F\u3001\u5973\u795E\u3078\u306E\u518D\u6226\u306B\u5F79\u7ACB\u3064\u5B58\u5728\u3068\u8A8D\u8B58\u3059\u308B\u3002"
