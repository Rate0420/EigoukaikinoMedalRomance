  charactorType: 0
  characterName: Amamiya Mei
  characterName_JP: "\u5929\u5BAE \u6FAA\u97F3"
  sprites:
  - {fileID: 21300000, guid: 34cf2da1e99648845a99560b0c798b6d, type: 3}
  - {fileID: 21300000, guid: d0329f69ee786ab488446e21fe10189a, type: 3}
  - {fileID: 21300000, guid: b77c8ff539b7eeb47ae9e1062c018d8d, type: 3}
  - {fileID: 21300000, guid: 1b98e6ea8db5ca94dbdb039f1a5315eb, type: 3}
  voice: []
  menuTexts:
  - "\u5148\u8F29\u3001\u6642\u306B\u306F\u4F11\u61A9\u3082\u5927\u5207\u3067\u3059\u3088\uFF1F"
  - "...\u5148\u8F29\u3001\u30B2\u30FC\u30E0\u3088\u308A\u79C1\u3092\u898B\u3066\u304F\u308C\u307E\u305B\u3093\u304B\uFF1F"
  - "\u4F55\u304B\u56F0\u308A\u3054\u3068\u304C\u3042\u308C\u3070\u3044\u3064\u3067\u3082\u3069\u3046\u305E\uFF01\\n\u7D76\u5BFE\u306B\u89E3\u6C7A\u3057\u3066\u898B\u305B\u307E\u3059\u304B\u3089\uFF01"
  - "...\u5148\u8F29\u306F\u3001\u79C1\u3092\u88CF\u5207\u308A\u307E\u305B\u3093\u3088\u306D\uFF1F"
  charaExp:
  - "\u4E3B\u4EBA\u516C\u306E\u5F8C\u8F29\u3092\u540D\u4E57\u308B\u5C11\u5973\u3002\u200B\\n\u5E38\u306B\u660E\u308B\u304F\u4EBA\u61D0\u3063\u3053\u3044\u7B11\u9854\u3067\u63A5\u3057\u3066\u304F\u308B\u304C\u3001\u3069\u3053\u304B\u8DDD\u96E2\u611F\u304C\u304A\u304B\u3057\u3044\u3002\\n\u3084\u305F\u3089\u3068\u5076\u7136\u3092\u88C5\u3063\u3066\u73FE\u308C\u3001\u4E3B\u4EBA\u516C\u306E\u884C\u52D5\u3084\u4E88\u5B9A\u3092\u300C\u306A\u305C\u304B\u300D\u628A\u63E1\u3057\u3066\u3044\u308B\u3002\\n\u597D\u610F\u306F\u96A0\u305D\u3046\u3068\u305B\u305A\u3001\u3080\u3057\u308D\u697D\u3057\u3080\u3088\u3046\u306B\u30A2\u30D7\u30ED\u30FC\u30C1\u3057\u3066\u304F\u308B\u3002\u200B\\n\u305F\u3060\u3057\u305D\u306E\u611B\u60C5\u306F\u4E00\u65B9\u901A\u884C\u3067\u306F\u306A\u304F\u3001\u200B\\n\u300C\u5148\u8F29\u306F\u3053\u3046\u3042\u308B\u3079\u304D\u300D\u3068\u3044\u3046\u7406\u60F3\u50CF\u3092\u62BC\u3057\u4ED8\u3051\u3066\u304F\u308B\u50BE\u5411\u304C\u3042\u308B\u3002\\n\u512A\u3057\u304F\u7518\u3048\u308B\u4E00\u65B9\u3067\u3001\u7406\u60F3\u304B\u3089\u5916\u308C\u305F\u77AC\u9593\u306B\u7A7A\u6C17\u304C\u51B7\u3048\u308B\u3088\u3046\u306A\u5371\u3046\u3055\u3092\u6301\u3064\u3002"
  - "\u200B \u88CF\u793E\u4F1A\u3092\u652F\u914D\u3059\u308B\u30DE\u30D5\u30A3\u30A2\u7D44\u7E54\u306E\u73FE\u30DC\u30B9\u3002\u200B\\n\u7236\u89AA\u3092\u6697\u6BBA\u3067\u5931\u3044\u3001\u305D\u306E\u5F8C\u306E\u7C9B\u6E05\u30FB\u88CF\u5207\u308A\u30FB\u6A29\u529B\u4E89\u3044\u3092\u7D4C\u3066\u30C8\u30C3\u30D7\u306B\u7ACB\u3063\u305F\u3002\u200B\\n\u305D\u306E\u904E\u7A0B\u3067\u300C\u4EBA\u306F\u5FC5\u305A\u88CF\u5207\u308B\u300D\u3068\u3044\u3046\u78BA\u4FE1\u3092\u6301\u3064\u306B\u81F3\u308B\u3002\u200B\\n\u5F7C\u5973\u306B\u3068\u3063\u3066\u4EBA\u9593\u95A2\u4FC2\u3068\u306F\u200B\\n\u5229\u7528\u3059\u308B\u304B\u5229\u7528\u3055\u308C\u308B\u304B\u306E\u3069\u3061\u3089\u304B\u3057\u304B\u5B58\u5728\u3057\u306A\u3044\u3002\u200B\\n\u3057\u304B\u3057\u4E3B\u4EBA\u516C\u3060\u3051\u306F\u9055\u3063\u305F\u3002\u4E3B\u4EBA\u516C\u306F\u6B32\u671B\u306B\u7D20\u76F4\uFF08\uFF1D\u91D1\u306B\u91E3\u3089\u308C\u308B\uFF09\u3057\u304B\u3057\u6839\u672C\u7684\u306B\u60AA\u3067\u306F\u306A\u3044\u3002\u200B\\n\u6253\u7B97\u3068\u5584\u6027\u304C\u540C\u5C45\u3057\u3066\u3044\u308B\u3068\u3044\u3046\u300C\u88CF\u5207\u308A\u305D\u3046\u3067\u88CF\u5207\u3089\u306A\u3044\u300D\u7D76\u5999\u306A\u30D0\u30E9\u30F3\u30B9\u3092\u6301\u3063\u3066\u3044\u308B\u3002\u200B\\n\u5F7C\u5973\u306F\u305D\u308C\u3092\u7406\u60F3\u306E\u4EBA\u3068\u3057\u3066\u8A8D\u8B58\u3057\u3066\u3057\u307E\u3046\u3002\u200B\\n\u305D\u306E\u7D50\u679C\u3001\\n\u4FE1\u3058\u305F\u3044\uFF08\u4F9D\u5B58\uFF09\u88CF\u5207\u3089\u305B\u305F\u304F\u306A\u3044\uFF08\u652F\u914D\uFF09\u7406\u60F3\u306E\u5F62\u306B\u3057\u305F\u3044\uFF08\u77EF\u6B63\uFF09\u200B\\n\u3068\u3044\u3046\u6B6A\u3093\u3060\u611B\u60C5\u304C\u5F62\u6210\u3055\u308C\u3066\u3044\u308B\u3002"
  likeability: 0
