  characterName: LilithRavenBlackwood
  characterName_JP: "\u30EA\u30EA\u30B9\u30FB\u30EC\u30A4\u30D6\u30F3\u30FB\u30D6\u30E9\u30C3\u30AF\u30A6\u30C3\u30C9"
  sprites:
  - {fileID: 21300000, guid: 99f0a9f9b729801468ba8e90a4b395c0, type: 3}
  - {fileID: 21300000, guid: 5ec406ce4414467479fa5c2d18593749, type: 3}
  - {fileID: 21300000, guid: 1e768c590568c5a4ab34485de69dd9d8, type: 3}
  - {fileID: 21300000, guid: b1d03a83393a2e442a1cdbf6a38b4a0c, type: 3}
  voice: []
  menuTexts:
  - "...\u541B\u3068\u4E00\u7DD2\u306A\u3089\u3001\u3069\u3053\u3067\u3082\u5065\u3084\u304B\u306B\u904E\u3054\u305B\u305D\u3046\u3060\u3002\\n...\u306A\u3093\u3068\u306A\u304F\u3001\u305D\u3093\u306A\u4E88\u611F\u304C\u3059\u308B\u3088\u3002"
  - "\u3084\u3041\u3001\u30A2\u30A4\u30C8\u3002\u4F55\u304B\u56F0\u308A\u3054\u3068\u306F\u306A\u3044\u304B\u3044\uFF1F"
  - "...\u30A2\u30A4\u30C8\u3001\u8AB0\u304B\u82E6\u3057\u3093\u3067\u3044\u308B\u4EBA\u3092\u898B\u306A\u304B\u3063\u305F\u304B\u3044\uFF1F\\n...\u305D\u3046\u304B\u3001\u898B\u3066\u3044\u306A\u3044\u304B..."
  - "\u541B\u306F\u79C1\u3092\u3059\u3054\u304F\u6C17\u306B\u304B\u3051\u3066\u304F\u308C\u3066\u3044\u308B\u306D\u3002\\n\u305D\u3053\u307E\u3067\u6C17\u306B\u304B\u3051\u3066\u304F\u308C\u308B\u4EBA\u306F\u521D\u3081\u3066\u3060\u3002...\u541B\u306F\u3001\u512A\u3057\u3044\u3093\u3060\u306D\u3002"
  charaExp:
  - "\u3069\u3053\u304B\u3089\u3068\u3082\u306A\u304F\u73FE\u308C\u308B\u8B0E\u306E\u5C11\u5973\u3002\u200B\\n\u5E74\u9F62\u4E0D\u8A73\u3002\u7269\u9759\u304B\u3067\u3001\u3069\u3053\u304B\u6D6E\u4E16\u96E2\u308C\u3057\u305F\u96F0\u56F2\u6C17\u3092\u6301\u3064\u3002\u200B\\n\u5E38\u306B\u843D\u3061\u7740\u3044\u305F\u53E3\u8ABF\u3067\u8A71\u3057\u3001\u7A4F\u3084\u304B\u306A\u5FAE\u7B11\u307F\u3092\u6D6E\u304B\u3079\u3066\u3044\u308B\u3002\u200B\\n\u8857\u4E2D\u3084\u8DEF\u5730\u88CF\u306A\u3069\u3001\u4EBA\u6C17\u306E\u5C11\u306A\u3044\u5834\u6240\u3067\u4E3B\u4EBA\u516C\u3068\u906D\u9047\u3059\u308B\u3053\u3068\u304C\u591A\u304F\u3001\\n\u4F1A\u8A71\u81EA\u4F53\u306F\u6210\u7ACB\u3059\u308B\u304C\u3001\u3069\u3053\u304B\u201C\u30BA\u30EC\u201D\u3092\u611F\u3058\u308B\u3002\u200B\\n\u5999\u306B\u9054\u89B3\u3057\u3066\u304A\u308A\u3001\u6B7B\u751F\u89B3\u306B\u3064\u3044\u3066\u3088\u304F\u8A71\u3059\u3002"
  - "19\u4E16\u7D00\u30ED\u30F3\u30C9\u30F3\u306E\u30B9\u30E9\u30E0\u51FA\u8EAB\u3002\u200B\\n\u6B7B\u306A\u306A\u3044\u305F\u3081\u306B\u751F\u304D\u308B\u74B0\u5883\u3067\u80B2\u3063\u305F\u5C11\u5973\u3002\u200B\\n\u7015\u6B7B\u306E\u7537\u304B\u3089\u53D7\u3051\u53D6\u3063\u305F\u601D\u60F3\u2015\u2015\u200B\\n\u300C\u6551\u6E08\u3068\u306F\u3001\u7D42\u308F\u3089\u305B\u308B\u3053\u3068\u300D\u200B\\n\u3092\u7D76\u5BFE\u7684\u306A\u771F\u7406\u3068\u3057\u3066\u53D7\u3051\u5165\u308C\u3066\u3057\u307E\u3046\u3002\\n\u4EE5\u964D\u3001\u5F7C\u5973\u306F\u200B\\n\u300C\u82E6\u3057\u3093\u3067\u3044\u308B\u8005\u3092\u201C\u6551\u3046\u201D\u305F\u3081\u306B\u6BBA\u3059\u300D\\n\u5B58\u5728\u3078\u3068\u5909\u308F\u3063\u305F\u3002\u200B\\n\u5F7C\u5973\u306F\u5FEB\u697D\u6BBA\u4EBA\u8005\u3067\u306F\u306A\u3044
    \u72C2\u3063\u3066\u3044\u308B\u81EA\u899A\u3082\u306A\u3044 \u5584\u610F100%\u306E\u6BBA\u4EBA\u9B3C\u200B\\n\u30C8\u30FC\u30CA\u30E1\u30F3\u30C8\u306B\u53EC\u559A\u3055\u308C\u305F\u5F8C\u3001\u6557\u5317\u3002\u200B\\n\u305D\u306E\u5F8C\u3082\u5143\u306E\u4E16\u754C\u306B\u623B\u308C\u305A\u3001\u73FE\u4EE3\u306B\u53D6\u308A\u6B8B\u3055\u308C\u308B\u3002\u200B\\n\u3057\u304B\u3057\u5F7C\u5973\u306F\u305D\u308C\u3092\u300C\u3088\u308A\u591A\u304F\u3092\u6551\u3046\u305F\u3081\u306E\u821E\u53F0\u300D\u3068\u89E3\u91C8\u3057\u3066\u304A\u308A\u3001\u4ECA\u65E5\u3082\u201D\u6551\u6E08\u201D\u3092\u4E0E\u3048\u3066\u56DE\u3063\u3066\u3044\u308B\u3002\u200B"
