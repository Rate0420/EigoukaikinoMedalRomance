  - "\u5927\u5B663\u5E74\u306E21\u6B73\u3002\u200B\\n\u501F\u91D1\u307E\u307F\u308C\u306E\u30A2\u30A4\u30C8\u306F\u3042\u308B\u65E5\u3001\u5947\u5999\u306A\u5922\u3092\u898B\u308B\u3002\u200B\\n\u305D\u306E\u5922\u3068\u306F\u30A2\u30A4\u30C8\u306E\u76EE\u306E\u524D\u306B\u5973\u795E\u304C\u73FE\u308C\u3001\u5F7C\u5973\u3092\u4F5C\u308C\u3068\u3044\u3046\u3082\u306E\u3002\\n\u3057\u304B\u3057\u30A2\u30A4\u30C8\u306F\u5973\u6027\u7D4C\u9A13\u304C\u5168\u304F\u306A\u3044\u3068\u62D2\u5426\u3059\u308B\u3068\u3001\\n\u4ED5\u65B9\u306A\u304F\u3068\u3044\u3046\u611F\u3058\u3067\u7279\u6B8A\u80FD\u529B\u3092\u3082\u3089\u3046\u3002\u200B\\n\\n\u305D\u306E\u7279\u6B8A\u80FD\u529B\u3068\u306F\u3001\\n\u91D1\u3092\u4F7F\u3063\u305F\u30E1\u30C0\u30EB\u30B2\u30FC\u30E0\u3092\u3059\u308B\u3053\u3068\u3067\u3001\u91D1\u3092\u7A3C\u304E\u3001\u604B\u611B\u3082\u6709\u5229\u306B\u9032\u3080\u3068\u3044\u3046\u7269\u3002\\n\\n\u30A2\u30A4\u30C8\u306F\u91D1\u3092\u7A3C\u3050\u3068\u3044\u3046\u70B9\u306B\u3064\u3089\u308C\u3001\u3042\u3063\u3055\u308A\u4E86\u627F\u3057\u3066\u3057\u307E\u3046\u3002\u200B\\n...\u5F7C\u306F\u307E\u3060\u77E5\u3089\u306A\u3044\u3002\u60A0\u4E45\u306E\u7262\u7344\u3078\u56DA\u308F\u308C\u3066\u3057\u307E\u3063\u305F\u3053\u3068\u306B\u3002\u200B\\n\\n(\u5B9F\u306F\u6C38\u9060\u30681\u5E74\u9593\u3092\u30EB\u30FC\u30D7\u3059\u308B\u3053\u3068\u306B\u306A\u308B)"
