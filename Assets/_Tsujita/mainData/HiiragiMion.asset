  m_Name: HiiragiMion
  m_EditorClassIdentifier: 
  charactorType: 3
  characterName: Hiiragi Mion
  characterName_JP: "\u67CA \u6FAA\u97F3"
  sprites:
  - {fileID: 21300000, guid: 2d8b6d27ad352f64c8365201bd10e244, type: 3}
  - {fileID: 21300000, guid: cbb4a1cc7eea9864f897392a842d1995, type: 3}
  - {fileID: 21300000, guid: 09eb31aa017ce8d42b579971f3b6757b, type: 3}
  - {fileID: 21300000, guid: 8135a31a5f8c79646bace71b27dd29f7, type: 3}
  voice: []
  menuTexts:
  - "...\u30A2\u30A4\u30C8\u3001\u6700\u8FD1\u5909\u306A\u6C17\u914D\u3068\u304B...\u611F\u3058\u306A\u3044\u3088\u306D\uFF1F\\n...\u306A\u3089\u3044\u3044\u3093\u3060\u3051\u3069\u3002"
  - "...\u79C1\u3055\u3001\u30A2\u30A4\u30C8\u3068\u4E00\u7DD2\u306E\u3053\u306E\u751F\u6D3B\u3001\u6C17\u306B\u5165\u3063\u3066\u308B\u3088\u3002\\n...\u305D\u308C\u3060\u3051\u3002"
  - "\u9762\u5012\u4E8B\u3070\u3063\u304B\u308A\u3060\u306D\u3047\u3001\u307E\u3001\u9811\u5F35\u308B\u304B\u3041..."
  - "\u30A2\u30A4\u30C8\u30FC\\n\u4ECA\u65E5\u3082\u304A\u90AA\u9B54\u3055\u305B\u3066\u3082\u3089\u3046\u304B\u3089\u306D\u30FC"
  charaExp:
  - "\u4E3B\u4EBA\u516C\u306E\u5E7C\u99B4\u67D3\u3067\u540C\u7D1A\u751F\u3002\u200B\\n\u6C17\u5B89\u304F\u3066\u8DDD\u96E2\u304C\u8FD1\u304F\u3001\u9060\u616E\u306A\u304F\u5BB6\u306B\u4E0A\u304C\u308A\u8FBC\u3093\u3067\u304F\u308B\u30BF\u30A4\u30D7\u3002\u200B\\n\u57FA\u672C\u306F\u3060\u3089\u3057\u306A\u304F\u3066\u9069\u5F53\u3002\u8AB2\u984C\u306F\u30AE\u30EA\u30AE\u30EA\u3001\u751F\u6D3B\u529B\u3082\u4F4E\u3081\u3002\u200B\\n\u3057\u304B\u3057\u5999\u306B\u9762\u5012\u898B\u304C\u3088\u304F\u3001\u4E3B\u4EBA\u516C\u306E\u751F\u6D3B\u306B\u306F\u81EA\u7136\u3068\u5165\u308A\u8FBC\u3093\u3067\u3044\u308B\u3002\\n\u4E21\u89AA\u3068\u306E\u95A2\u4FC2\u304C\u3042\u307E\u308A\u826F\u304F\u306A\u3044\u3089\u3057\u304F\u3001\u200B\\n\u300C\u306A\u3093\u3068\u306A\u304F\u5C45\u5FC3\u5730\u304C\u3044\u3044\u304B\u3089\u300D\u3068\u3044\u3046\u7406\u7531\u3067\u3088\u304F\u4E3B\u4EBA\u516C\u306E\u5BB6\u306B\u6CCA\u307E\u308A\u306B\u6765\u308B\u3002\\n\u307E\u305F\u3001\u6614\u304B\u3089\u5468\u56F2\u3067\u5909\u306A\u3053\u3068\u3084\u4E0D\u5E78\u306A\u3053\u3068\u304C\u8D77\u304D\u3084\u3059\u3044\u4F53\u8CEA\u3067\u3042\u308B\u3002"
  - "\u672C\u540D\u306F\u7953\u5DDD \u6FAA\u97F3\u3002\u707D\u5384\u3092\u7953\u3046\u5DEB\u5973\u306E\u540D\u5BB6\u300C\u7953\u5DDD\u5BB6\u300D\u306E\u6B63\u7D71\u5F8C\u7D99\u8005\u3002\u200B         
    \\n\u30C0\u30E0\u5EFA\u8A2D\u306B\u3088\u3063\u3066\u6751\u304C\u6C88\u3093\u3060\u969B\u3001\u707D\u3044\uFF08\u970A\u7684\u306A\u4F55\u304B\uFF09\u306E\u66B4\u8D70\u304C\u8D77\u304D\u3001\u5BB6\u65CF\u3068\u96E2\u6563\u3002\u200B\\n\u305D\u306E\u6DF7\u4E71\u306E\u4E2D\u3067\u73FE\u5728\u306E\u91CC\u89AA\u306B\u5F15\u304D\u53D6\u3089\u308C\u3001\u904E\u53BB\u306E\u8A18\u61B6\u3084\u51FA\u81EA\u306F\u307B\u307C\u5931\u308F\u308C\u3066\u3044\u308B\u3002\\n\u5F7C\u5973\u306F\u81EA\u899A\u3057\u3066\u3044\u306A\u3044\u304C\u3001\u5F37\u529B\u306A\u970A\u5A92\u4F53\u8CEA\u3067\u970A\u3092\u5F15\u304D\u5BC4\u305B\u308B\u3068\u540C\u6642\u306B\u7279\u7570\u306A\u7953\u3044\u306E\u529B\u3067\u7121\u610F\u8B58\u306B\u6D88\u3059\u200B\\n\u3068\u3044\u3046\u201C\u77DB\u76FE\u3057\u305F\u6027\u8CEA\u201D\u3092\u6301\u3064\u3002\\n\u305D\u306E\u305F\u3081\u707D\u3044\u3092\u547C\u3073\u5BC4\u305B\u3066\u306F\u3001\u81EA\u52D5\u3067\u6392\u9664\u3059\u308B\u3068\u3044\u3046\u73FE\u8C61\u304C\u5E38\u306B\u767A\u751F\u3057\u3066\u3044\u308B\u3002\u200B\\n\u7D50\u679C\u3068\u3057\u3066\u5F7C\u5973\u306E\u5468\u56F2\u3067\\n\u300C\u4E0D\u5E78\u306A\u51FA\u6765\u4E8B\u304C\u8D77\u304D\u304B\u3051\u308B\u300D\\n\u300C\u3057\u304B\u3057\u6700\u60AA\u306E\u7D50\u679C\u3060\u3051\u306F\u56DE\u907F\u3055\u308C\u308B\u307E\u305F\u306F\u4E0D\u5E78\u306F\u6FAA\u97F3\u4EE5\u5916\u306B\u62BC\u3057\u4ED8\u3051\u3089\u308C\u308B\u300D\\n\u3068\u3044\u3046\u6B6A\u306A\u72B6\u614B\u306B\u306A\u308B\\n\u672C\u4EBA\u306F\u3053\u308C\u3092\u300C\u81EA\u5206\u304C\u3044\u308B\u3068\u5468\u308A\u306B\u8FF7\u60D1\u304C\u304B\u304B\u308B\u300D\u3068\u8A8D\u8B58\u3057\u3066\u3044\u308B\u304C\u3001\u6DF1\u304F\u8003\u3048\u306A\u3044\u3088\u3046\u306B\u3057\u3066\u3044\u308B\u3002\u200B "
  likeability: 0
