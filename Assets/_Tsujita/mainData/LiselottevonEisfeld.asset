  characterName: LiselottevonEisfeld
  characterName_JP: "\u30EA\u30FC\u30BC\u30ED\u30C3\u30C6\u30FB\u30D5\u30A9\u30F3\u30FB\u30A2\u30A4\u30B9\u30D5\u30A7\u30EB\u30C8"
  sprites:
  - {fileID: 21300000, guid: 46f6ab5ccbb7d924a869f79a12f7281f, type: 3}
  - {fileID: 21300000, guid: e9b86f90356c1874282aa76ca192b853, type: 3}
  - {fileID: 21300000, guid: 0fe58bd35f2486946b089993062c6d75, type: 3}
  - {fileID: 21300000, guid: 725a3a55bf7eaef45b4247466cfbcd82, type: 3}
  voice: []
  menuTexts:
  - "\u5C11\u5E74\uFF01\uFF01\u30B2\u30FC\u30E0\u3070\u304B\u308A\u3057\u3066\u3044\u306A\u3044\u3067\u4E00\u7DD2\u306B\u5916\u306B\u884C\u3053\u3046\uFF01\uFF01\uFF01\uFF01"
  - "\u5C11\u5E74\uFF01\uFF01\u304A\u8179\u304C\u3059\u3044\u305F\u304B\u3089\u4F55\u304B\u4F5C\u3063\u3066\u307B\u3057\u3044\uFF01\uFF01"
  - "\u5C11\u5E74\u3001\u4E00\u7DD2\u306B\u8857\u3092\u5DE1\u56DE\u3057\u306A\u3044\u304B\uFF1F\\n...\u3082\u3061\u308D\u3093\u3001\u60AA\u3044\u5974\u3092\u898B\u3064\u3051\u3066\u6210\u6557\u3059\u308B\u305F\u3081\u3060\uFF01"
  - "...\u3042\u307E\u308A\u9589\u3058\u3053\u3082\u308B\u306E\u306F\u597D\u304D\u3067\u306F\u306A\u3044\u304C...\\n\u5C11\u5E74\u3068\u4E00\u7DD2\u306A\u3089...\u5ACC...\u3067\u306F\u306A\u3044\u306A\u3002\u3046\u3093..."
  charaExp:
  - "\u540D\u9580\u30A2\u30A4\u30B9\u30D5\u30A7\u30EB\u30C8\u5BB6\u306B\u751F\u307E\u308C\u305F\u9A0E\u58EB\u4EE4\u5B22\u3002\\n\u5E7C\u5C11\u671F\u304B\u3089\u201C\u9A0E\u58EB\u3068\u306F\u4F55\u304B\u201D\u3092\u53E9\u304D\u8FBC\u307E\u308C\u3066\u304D\u305F\u3002\u200B\\n\u5F7C\u5973\u306E\u4FE1\u5FF5\u306F\u30B7\u30F3\u30D7\u30EB\u3067\u3042\u308A\u3001\u884C\u52D5\u306E\u3059\u3079\u3066\u306F\\n\u300C\u9A0E\u58EB\u306F\u5E38\u306B\u6B63\u3057\u304F\u3001\u5F37\u304F\u3001\u7F8E\u3057\u304F\u3042\u308B\u3079\u304D\u300D\\n\u306B\u57FA\u3065\u3044\u3066\u3044\u308B\u3002\u200B\\n\u3057\u304B\u3057\u305D\u306E\u4FA1\u5024\u89B3\u306F\u201C\u7406\u60F3\u3068\u3057\u3066\u6559\u3048\u8FBC\u307E\u308C\u305F\u3082\u306E\u201D\u3067\u3042\u308A\u3001\u73FE\u5B9F\u3092\u3042\u307E\u308A\u77E5\u3089\u306A\u3044\u3002\\n\u672C\u8CEA\u7684\u306A\u554F\u984C\u3068\u3057\u3066\u5F7C\u5973\u306F\u6B63\u7FA9\u3092\u7591\u308F\u306A\u3044\u3001\u81EA\u5206\u306E\u6B63\u3057\u3055\u3092\u7591\u308F\u306A\u3044\u3002\\n\u3064\u307E\u308A\u300C\u8FF7\u308F\u306A\u3044\u5F37\u3055\u300D\u3068\u300C\u8003\u3048\u306A\u3044\u5371\u3046\u3055\u300D\u3092\u540C\u6642\u306B\u6301\u3064\u3002"
  - "\u4EE5\u524D\u30F4\u30A7\u30EB\u30DF\u30EA\u30AA\u30F3\u306E\u5C4B\u6577\u306B\u8FF7\u3044\u8FBC\u307F\u6226\u3044\u306B\u306A\u308A\u3001\u8A0E\u4F10\u3059\u308B\u3002\\n\u8A0E\u4F10\u3055\u308C\u3066\u30F4\u30A7\u30EB\u30DF\u30EA\u30AA\u30F3\u304C\u6D88\u3048\u308B\u76F4\u524D\u306B\\n\u5973\u795E\u306B\u3088\u3063\u3066\u30F4\u30A7\u30EB\u30DF\u30EA\u30AA\u30F3\u306F\u8EE2\u79FB\u3055\u305B\u3089\u308C\u3001\u30C8\u30FC\u30CA\u30E1\u30F3\u30C8\u306B\u547C\u3070\u308C\u308B\u3002\\n\u305D\u308C\u306B\u5DFB\u304D\u8FBC\u307E\u308C\u3001\u53C2\u52A0\u3053\u305D\u3057\u3066\u3044\u306A\u3044\u3082\u306E\u306E\u30EA\u30FC\u30BC\u30ED\u30C3\u30C6\u3082\u73FE\u4EE3\u3078\u98DB\u3070\u3055\u308C\u308B\u3002\u200B\\n\u30F4\u30A7\u30EB\u30DF\u30EA\u30AA\u30F3\u306F\u4E00\u5EA6\u5012\u3057\u3066\u3044\u308B\u304C\u3001\\n\u300C\u7406\u89E3\u3067\u304D\u306A\u3044\u5B58\u5728\u306B\u521D\u3081\u3066\u6557\u5317\u5BF8\u524D\u307E\u3067\u8FFD\u3044\u8FBC\u307E\u308C\u305F\u76F8\u624B\u300D\u3067\u3042\u308B\u3002\\n\u6226\u3044\u3068\u3057\u3066\u306F\u52DD\u5229\u3002\u4FA1\u5024\u89B3\u3068\u3057\u3066\u306F\u6557\u5317\u3002\u200B\\n\u7406\u7531\u3068\u3057\u3066\u3001\u30F4\u30A7\u30EB\u30DF\u30EA\u30AA\u30F3\u306F\u5584\u60AA\u3067\u52D5\u3044\u3066\u304A\u3089\u305A\u3001\u5F37\u3055\u306E\u307F\u3092\u57FA\u6E96\u306B\u3057\u3066\u3044\u308B\u200B\\n\u3064\u307E\u308A\u3001\u30EA\u30FC\u30BC\u30ED\u30C3\u30C6\u306E\u7406\u5FF5\u3067\u3042\u308B\u30EA\u30FC\u30BC\u30ED\u30C3\u30C6\u306E\u300C\u9A0E\u58EB\u9053\u300D\u304C\u901A\u3058\u306A\u3044\\n\u3053\u306E\u7D4C\u9A13\u304C\u5F7C\u5973\u306E\u4E2D\u3067\u672A\u6D88\u5316\u306E\u307E\u307E\u6B8B\u3063\u3066\u3044\u308B\u3002\u200B\\n\u5F37\u304F\u3001\u6B63\u3057\u3044\uFF08\u3064\u3082\u308A\uFF09\u3067\u3082\u4E16\u754C\u306F\u305D\u308C\u3060\u3051\u3058\u3083\u306A\u3044\u3000\u3068\u3044\u3046\u3053\u3068\u3067\u51C4\u304F\u60A9\u3093\u3067\u3044\u308B\u3002"
